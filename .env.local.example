# Copy to .env.local and set real values.

# Contact form recipient (required)
CONTACT_EMAIL=kstrategic_inc@outlook.com
# Optional public fallback for non-secret environments
NEXT_PUBLIC_CONTACT_EMAIL=kstrategic_inc@outlook.com

# Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM="RealAcademiQ <onboarding@resend.dev>"

# SMTP fallback
SMTP_HOST=smtp.outlook.com
SMTP_PORT=587
SMTP_USER=kstrategic_inc@outlook.com
SMTP_PASS=your_outlook_app_password
EMAIL_FROM="RealAcademiQ <kstrategic_inc@outlook.com>"

# App URL for payment redirects
NEXT_PUBLIC_APP_URL=https://your-domain.com

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# M-Pesa Daraja
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-mpesa-passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback
# Optional extra callback header secret
MPESA_CALLBACK_SECRET=your-random-shared-secret
