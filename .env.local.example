###############################################################
# Copy this file to .env.local and fill in the values.
#
# SMTP configuration example for sending emails from contact forms
# Fill in your actual credentials and keep this file secure!
###############################################################

###############################################################
# Destination email where contact form messages are delivered
# This is the recipient address for contact form submissions
CONTACT_EMAIL=your_contact_email@example.com

###############################################################
# Recommended provider: Resend (avoids many SMTP auth issues)
# RESEND_API_KEY: Your Resend API key (starts with re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# RESEND_FROM: Verified sender identity in Resend dashboard
RESEND_FROM=RealAcademiQ <onboarding@resend.dev>

###############################################################
# SMTP settings (alternative to Resend)
# SMTP_HOST: The hostname of your SMTP provider (e.g., smtp.outlook.com)
SMTP_HOST=smtp.your-provider.com
# SMTP_PORT: The port for SMTP (usually 587 for TLS)
SMTP_PORT=587
# SMTP_USER: The username/email for SMTP authentication
SMTP_USER=your_smtp_username@example.com
# SMTP_PASS: The password or app-specific password for SMTP authentication
SMTP_PASS=your_smtp_password

###############################################################
# Firebase Configuration (for order management + admin dashboard)
# Get these from: https://console.firebase.google.com
# Project Settings → General tab
# apiKey
NEXT_PUBLIC_FIREBASE_API_KEY=
# authDomain
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# projectId
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# storageBucket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# messagingSenderId
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# appId
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin Credentials (for server-side operations)
# Generate from: https://console.firebase.google.com
# Project Settings → Service Accounts → Generate Private Key
# project_id
FIREBASE_PROJECT_ID=
# client_email
FIREBASE_CLIENT_EMAIL=
# Option A: private_key (escape new lines with \n)
FIREBASE_PRIVATE_KEY=""
# Option B (recommended): base64-encoded full private_key PEM
FIREBASE_PRIVATE_KEY_BASE64=

###############################################################
# Optional: override the "From" address shown in the email header
# EMAIL_FROM: Custom sender address (e.g., "RealAcademiQ <no-reply@example.com>")
# EMAIL_FROM=RealAcademiQ <no-reply@example.com>
