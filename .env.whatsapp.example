# WhatsApp Notification Setup (Twilio)
# Add these to your .env.local file to enable WhatsApp notifications

# Twilio WhatsApp credentials
# Get these from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_PHONE=whatsapp:+1234567890

# Numbers to notify
# ADMIN_WHATSAPP_PHONE=whatsapp:+254101582198
# CLIENT_WHATSAPP_PHONE=whatsapp:+client_phone_number

# Application URL for links
# NEXT_PUBLIC_APP_URL=https://real-academi-q.vercel.app
